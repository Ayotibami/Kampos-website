# Public production URL, used to build absolute social-preview URLs
# (og:url / og:image) in public/index.html.
#
# Link scrapers (WhatsApp, X, Slack…) will not resolve relative paths, so these
# have to be absolute. This file is the committed default; to point at a custom
# domain later, set REACT_APP_SITE_URL in the Vercel project's Environment
# Variables — a real env var overrides this file at build time, so no code
# change is needed.
#
# No trailing slash.
REACT_APP_SITE_URL=https://kampos-website.vercel.app

# Web3Forms access key — powers the Contact, Bug report and Feature request
# form submissions (see src/api/feedback.js). This is a *public* key by design:
# Web3Forms keys live in client-side code, and CRA inlines REACT_APP_* vars into
# the bundle anyway, so there is nothing secret here. Regenerate it at
# web3forms.com if it ever needs rotating.
REACT_APP_WEB3FORMS_KEY=2d4b0728-aabe-4e11-807f-e25532e0f9f3

# Destination of the "Korner" button in the header (desktop nav + mobile menu).
# Change it here or in Vercel's Environment Variables — no code change needed.
REACT_APP_KORNER_URL=https://korner-frontend.vercel.app/

# Destination of every "Hop into Kampos" CTA — the live Kampos web app.
# TODO: set this to the real app URL. Change here or in Vercel; no code change.
REACT_APP_KAMPOS_URL=https://kampos-website.vercel.app
